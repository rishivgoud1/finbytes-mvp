# ─── PostgreSQL ──────────────────────────────────────────────
DB_USER=finbytes_user
DB_PASSWORD=change_me_locally
DB_NAME=finbytes_db
DB_HOST=localhost
DB_PORT=5432

# Prisma reads this directly
DATABASE_URL="postgresql://finbytes_user:change_me_locally@localhost:5432/finbytes_db?schema=public"

# ─── pgAdmin (optional GUI) ─────────────────────────────────
PGADMIN_EMAIL=admin@finbytes.local
PGADMIN_PASSWORD=pgadminpassword

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development